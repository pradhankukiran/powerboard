{
  "name": "powerboard",
  "private": true,
  "version": "0.1.0",
  "description": "MSP client portal with embedded BI dashboards",
  "scripts": {
    "dev:api": "pnpm --filter @powerboard/api dev",
    "dev:web": "pnpm --filter @powerboard/web dev",
    "build:api": "pnpm --filter @powerboard/api build",
    "build:web": "pnpm --filter @powerboard/web build",
    "typecheck": "pnpm -r typecheck",
    "seed": "pnpm --filter @powerboard/api seed"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  }
}
